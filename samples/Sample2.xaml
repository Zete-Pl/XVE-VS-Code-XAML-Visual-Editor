<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Przykładowe okno" Width="640" Height="480">
	<Grid>
		<TextBlock Text="Example form" FontSize="24" FontWeight="Bold" Margin="20,16,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<Button Content="OK" Width="100" Height="32" Margin="20,70,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<Button Content="Cancel" Width="100" Height="32" Margin="20,112,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<Border BorderBrush="Gray" BorderThickness="1" Background="#2F777777" CornerRadius="6" Width="240" Height="160" Margin="160,70,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
			<StackPanel Margin="12">
				<TextBlock Text="Settings" FontWeight="Bold" TextAlignment="Center" />
				<CheckBox Content="Option one" Margin="0,8,0,0" IsChecked="True" />
				<CheckBox Content="Option two" Margin="0,4,0,0" IsChecked="False" />
				<Slider Width="180" Margin="0,12,0,0" Value="75" Maximum="100" />
			</StackPanel>
		</Border>
		<Ellipse Fill="LightGreen" Stroke="Green" StrokeThickness="2" Width="90" Height="90" Margin="440,80,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<TextBox Text="Enter text..." Width="220" Height="28" Margin="20,260,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<ProgressBar Value="25" Width="220" Height="16" Margin="20,300,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#44666666" />
	</Grid>
</Window>