<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Text wrapping" Width="420" Height="360">
	<!-- Web dziś robi white-space:pre (jedna linia). WPF zawija TextWrapping="Wrap" w stałej szerokości,
	     więc ActualWidth/ActualHeight TextBlocków będzie się mocno różnić. -->
	<StackPanel Margin="12">
		<TextBlock Width="200" TextWrapping="Wrap" FontSize="14"
			Text="To jest długi akapit, który w WPF zawinie się do wielu linii wewnątrz kolumny o szerokości 200 jednostek, a w renderze web bez obsługi zawijania zostanie jedną linią." />
		<TextBlock Width="200" TextWrapping="WrapWithOverflow" FontSize="14" Margin="0,12,0,0"
			Text="WrapWithOverflow: pojedyncze niełamliwe wyrazy mogą wystawać poza szerokość, ale reszta zawija normalnie." />
		<TextBlock Width="200" TextWrapping="NoWrap" FontSize="14" Margin="0,12,0,0"
			Text="NoWrap: ten tekst nie powinien się zawijać w żadnym backendzie." />
		<TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,12,0,0"
			Text="Bez jawnej szerokości — zawijanie zależy od szerokości dostępnej od rodzica (StackPanel = szerokość okna)." />
	</StackPanel>
</Window>
