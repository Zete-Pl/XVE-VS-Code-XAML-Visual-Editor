<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Przykładowe okno" Width="640" Height="480">
	<Grid>
		<TextBlock Text="Przykładowy formularz" FontSize="24" FontWeight="Bold" Margin="20,16,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<Button Content="OK" Width="100" Height="32" Margin="20,70,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<Button Content="Anuluj" Width="100" Height="32" Margin="20,112,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<Border BorderBrush="Gray" BorderThickness="1" Background="#2F777777" CornerRadius="6" Width="240" Height="160" Margin="160,70,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
			<StackPanel Margin="12">
				<TextBlock Text="Ustawienia" FontWeight="Bold" />
				<CheckBox Content="Opcja pierwsza" Margin="0,8,0,0" />
				<CheckBox Content="Opcja druga" Margin="0,4,0,0" />
				<Slider Width="180" Margin="0,12,0,0" Value="35" Maximum="100" />
			</StackPanel>
		</Border>
		<Ellipse Fill="LightGreen" Stroke="Green" StrokeThickness="2" Width="90" Height="90" Margin="440,80,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<TextBox Text="Wpisz tekst..." Width="220" Height="28" Margin="20,260,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<ProgressBar Value="60" Width="220" Height="16" Margin="20,300,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
	</Grid>
</Window>