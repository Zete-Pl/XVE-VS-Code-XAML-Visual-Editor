<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Grid star/auto" Width="480" Height="320">
	<!-- Mieszanka Auto / * / 2* / px + RowSpan/ColumnSpan. Dystrybucja gwiazdek po odjęciu auto/fixed
	     bywa inna we flexie CSS (fr) niż w WPF Measure/Arrange. -->
	<Grid Margin="8">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="2*" />
			<ColumnDefinition Width="80" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="40" />
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" Grid.Column="0" Text="Auto-kol" />
		<Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Background="#FFB0C4DE" />
		<Border Grid.Row="1" Grid.Column="0" Background="#FFFFE4B5" />
		<Border Grid.Row="1" Grid.Column="1" Background="#FF90EE90" />
		<Border Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" Background="#FFFFA07A" />
		<Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="#FFDDA0DD" />
		<Border Grid.Row="1" Grid.Column="3" Background="#FFADD8E6" />
	</Grid>
</Window>
