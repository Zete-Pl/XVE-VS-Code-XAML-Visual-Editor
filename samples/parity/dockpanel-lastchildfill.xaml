<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="DockPanel LastChildFill" Width="480" Height="360">
	<!-- Sekwencyjne dokowanie + LastChildFill. Każde kolejne dziecko zabiera pas z malejącego
	     prostokąta; ostatnie wypełnia resztę. Web emuluje to zagnieżdżonym flexem. -->
	<DockPanel LastChildFill="True">
		<Border DockPanel.Dock="Top" Height="36" Background="#FFB0C4DE" />
		<Border DockPanel.Dock="Bottom" Height="28" Background="#FFDDA0DD" />
		<Border DockPanel.Dock="Left" Width="100" Background="#FFFFE4B5" />
		<Border DockPanel.Dock="Right" Width="80" Background="#FFADD8E6" />
		<Border Background="#FF90EE90" />
	</DockPanel>
</Window>
