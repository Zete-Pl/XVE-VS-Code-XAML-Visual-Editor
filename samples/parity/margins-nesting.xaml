<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Margins nesting" Width="420" Height="360">
	<!-- Zagnieżdżone marginesy. WPF nigdy nie kolapsuje marginesów (sumuje); CSS w blokach potrafi,
	     w flexie nie — sprawdzamy, że pozycje dzieci są sumą marginesów rodzica i dziecka. -->
	<StackPanel Margin="20">
		<Border Background="#FFB0C4DE" Margin="10" HorizontalAlignment="Left">
			<StackPanel Margin="15">
				<TextBlock Text="Górny" Margin="0,0,0,10" />
				<TextBlock Text="Dolny" Margin="5,10,5,0" />
			</StackPanel>
		</Border>
		<Border Background="#FF90EE90" Margin="10,30,10,0" HorizontalAlignment="Left">
			<TextBlock Text="Po dużym górnym marginesie" Margin="8" />
		</Border>
	</StackPanel>
</Window>
