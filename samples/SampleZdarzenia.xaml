<Window x:Class="MojProjekt.OknoGlowne" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Okno z logiką" Width="640" Height="480" Loaded="Window_Loaded">
	<Window.Resources>
		<SolidColorBrush x:Key="AkcentBrush" Color="#FF2D7DD2" />
		<Style x:Key="NaglowekStyle" TargetType="TextBlock">
			<Setter Property="FontSize" Value="22" />
			<Setter Property="FontWeight" Value="Bold" />
			<Setter Property="Foreground" Value="{StaticResource AkcentBrush}" />
		</Style>
	</Window.Resources>
	<Grid>
		<TextBlock Text="Formularz z procedurami zdarzeń" Style="{StaticResource NaglowekStyle}" Margin="20,16,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<TextBox x:Name="PoleNazwa" Text="{Binding NazwaUzytkownika, UpdateSourceTrigger=PropertyChanged}" Width="220" Height="28" Margin="20,70,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" TextChanged="PoleNazwa_TextChanged" />
		<Button x:Name="PrzyciskZapisz" Content="Zapisz" Click="PrzyciskZapisz_Click" Background="{DynamicResource MotywTlaPrzycisku}" Width="100" Height="32" Margin="20,112,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<CheckBox Content="Zgoda na regulamin" IsChecked="{Binding Zgoda}" Checked="Zgoda_Checked" Unchecked="Zgoda_Checked" Margin="20,156,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
		<Border BorderBrush="{StaticResource AkcentBrush}" BorderThickness="1" CornerRadius="4" Width="240" Height="140" Margin="300,70,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
			<StackPanel Margin="10">
				<TextBlock Text="{Binding Opis}" TextWrapping="Wrap" />
				<ProgressBar Value="{Binding Postep}" Height="14" Margin="0,10,0,0" />
			</StackPanel>
		</Border>
	</Grid>
</Window>