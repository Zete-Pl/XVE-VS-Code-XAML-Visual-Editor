<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>xve-wpf-host</AssemblyName>
    <LangVersion>latest</LangVersion>
    <!-- ThemeMode (Fluent) jest oznaczone [Experimental] (WPF0001) — świadomie używamy -->
    <NoWarn>$(NoWarn);WPF0001</NoWarn>
    <!-- proces pomocniczy: bez okna, renderuje XAML do PNG + mapy hit-test -->
  </PropertyGroup>

</Project>
