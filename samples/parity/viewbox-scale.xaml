<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Viewbox scale" Width="420" Height="320">
	<!-- Viewbox skaluje treść o stałym rozmiarze logicznym do dostępnego miejsca. ActualWidth dzieci
	     pozostaje logiczny, ale renderowany rozmiar (transform) różni się — test skali. -->
	<Grid Margin="8">
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<Viewbox Grid.Row="0" Stretch="Uniform">
			<Border Width="200" Height="100" Background="#FFB0C4DE">
				<TextBlock Text="Uniform" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
			</Border>
		</Viewbox>
		<Viewbox Grid.Row="1" Stretch="Fill">
			<Border Width="200" Height="100" Background="#FF90EE90">
				<TextBlock Text="Fill" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
			</Border>
		</Viewbox>
	</Grid>
</Window>
