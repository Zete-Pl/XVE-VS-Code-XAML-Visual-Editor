<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Menu / ComboBox / ScrollViewer" Width="560" Height="420">
	<DockPanel>
		<!-- Menu: zaznacz MenuItem przy włączonym Auto-podglądzie, by rozwinąć submenu -->
		<Menu DockPanel.Dock="Top">
			<MenuItem Header="Plik">
				<MenuItem Header="Nowy" />
				<MenuItem Header="Otwórz" />
				<MenuItem Header="Zapisz" />
			</MenuItem>
			<MenuItem Header="Edycja">
				<MenuItem Header="Cofnij" />
				<MenuItem Header="Ponów" />
			</MenuItem>
		</Menu>

		<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12">
			<TextBlock Text="Tryb:" VerticalAlignment="Center" Margin="0,0,8,0" />
			<!-- ComboBox: zaznacz ComboBox lub pozycję, by rozwinąć listę (Auto-podgląd) -->
			<ComboBox Width="160" SelectedIndex="0">
				<ComboBoxItem Content="Projektowanie" />
				<ComboBoxItem Content="Podgląd" />
				<ComboBoxItem Content="Kod" />
			</ComboBox>
		</StackPanel>

		<!-- ScrollViewer: najedź kursorem i kręć kółkiem, by przewinąć tylko ten obszar -->
		<ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto" Background="#22777777">
			<StackPanel>
				<TextBlock Text="Pozycja 1" Margin="8" />
				<TextBlock Text="Pozycja 2" Margin="8" />
				<TextBlock Text="Pozycja 3" Margin="8" />
				<TextBlock Text="Pozycja 4" Margin="8" />
				<TextBlock Text="Pozycja 5" Margin="8" />
				<TextBlock Text="Pozycja 6" Margin="8" />
				<TextBlock Text="Pozycja 7" Margin="8" />
				<TextBlock Text="Pozycja 8" Margin="8" />
				<TextBlock Text="Pozycja 9" Margin="8" />
				<TextBlock Text="Pozycja 10" Margin="8" />
				<TextBlock Text="Pozycja 11" Margin="8" />
				<TextBlock Text="Pozycja 12" Margin="8" />
				<TextBlock Text="Pozycja 13" Margin="8" />
				<TextBlock Text="Pozycja 14" Margin="8" />
				<TextBlock Text="Pozycja 15" Margin="8" />
			</StackPanel>
		</ScrollViewer>
	</DockPanel>
</Window>
