<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Grid shared size" Width="420" Height="240">
	<!-- SharedSizeGroup: dwa Gridy współdzielą szerokość kolumny etykiet. Web tego nie wspiera,
	     więc kolumny etykiet rozjadą się względem WPF (twardy, oczekiwany rozjazd). -->
	<StackPanel Margin="12" Grid.IsSharedSizeScope="True">
		<Grid Margin="0,0,0,8">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<TextBlock Grid.Column="0" Text="Imię:" Margin="0,0,8,0" />
			<TextBox Grid.Column="1" Text="Jan" />
		</Grid>
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<TextBlock Grid.Column="0" Text="Nazwisko (dłuższa etykieta):" Margin="0,0,8,0" />
			<TextBox Grid.Column="1" Text="Kowalski" />
		</Grid>
	</StackPanel>
</Window>
